# Server
PORT=4000
HOST=127.0.0.1
DATABASE_URL=./data/rodoved.sqlite
SESSION_SECRET=change-this-long-random-string

# First admin account. In local development the app falls back to admin/admin
# if these values are absent. Production must set them explicitly.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
WORKSPACE_PASSWORD=change-me-too

# Frontend dev server can proxy /api, so this is usually empty locally.
VITE_API_BASE_URL=
